# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
VITE_APP_VERSION=1.0.0

# Auth Feature Flags
# When true, temporarily allow legacy device token auth alongside Supabase auth during migration
VITE_ENABLE_DEVICE_TOKEN_AUTH=false

# Google Gemini API Configuration
# Get your API key from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Email for MyMemory API (legacy - now using Gemini)
# TRANSLATION_EMAIL=your_email@example.com

# AI Insights Debugging & Rate Limits
# Set to true to enable verbose insights debug logs in console
VITE_AI_DEBUG=false