# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
VITE_APP_VERSION=1.0.0

# Auth Feature Flags
# When true, temporarily allow legacy device token auth alongside Supabase auth during migration
VITE_ENABLE_DEVICE_TOKEN_AUTH=false

# Gemini runs SERVER-SIDE only (receipt extraction + Telegram bot).
# It is NOT a client VITE_ var — set it as a Supabase Edge Function secret:
#   supabase secrets set GEMINI_API_KEY=...
#   supabase secrets set GEMINI_MODEL=gemini-2.5-flash   # optional

# Insights Debugging
# Set to true to enable verbose insights debug logs in console
VITE_AI_DEBUG=false