# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
VITE_APP_VERSION=1.0.0

# Auth Feature Flags
# When true, temporarily allow legacy device token auth alongside Supabase auth during migration
VITE_ENABLE_DEVICE_TOKEN_AUTH=false

# Receipt OCR runs SERVER-SIDE only (extract-receipt edge fn + Telegram bot),
# via OpenRouter. It is NOT a client VITE_ var — set it as a Supabase Edge
# Function secret. Free vision models are used by default; the prepaid balance
# is only a fallback and is not consumed by :free models.
#   supabase secrets set OPENROUTER_API_KEY=sk-or-...
#   # optional overrides (default = free cross-provider chain, max 3 models:
#   #   moonshotai/kimi-k2.6:free, nex-agi/nex-n2-pro:free, nvidia/nemotron-nano-12b-v2-vl:free)
#   supabase secrets set OPENROUTER_MODEL=moonshotai/kimi-k2.6:free
#   supabase secrets set OPENROUTER_MODELS=nex-agi/nex-n2-pro:free,nvidia/nemotron-nano-12b-v2-vl:free
# (GEMINI_API_KEY is no longer used by any code and can be removed.)

# Insights Debugging
# Set to true to enable verbose insights debug logs in console
VITE_AI_DEBUG=false